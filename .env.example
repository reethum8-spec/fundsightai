# Root example — copy into frontend/.env and backend/.env as needed.

# Frontend (Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_API_BASE_URL=http://localhost:5000
VITE_USE_MOCK=true

# Backend (Flask)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
FLASK_ENV=development
PORT=5000
USE_MOCK=true
JWT_SECRET=change-me
