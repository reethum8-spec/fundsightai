# Flask
FLASK_ENV=development        # change to 'production' for live deploy
PORT=5000
USE_MOCK=true                # set 'false' when Supabase is configured

# Supabase (backend uses service_role key for validated writes)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=         # optional: enables strict JWT verification

# Auth
JWT_SECRET=change-me         # MUST be changed in production (≥32 random bytes)

# CORS (comma-separated, no spaces)
CORS_ORIGINS=http://localhost:5173

# AI (optional override)
# FS_MODELS_DIR=/absolute/path/to/ai_models/models
